rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USUARIOS
    // ============================================
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    
    // ============================================
    // LABORATORIOS
    // ============================================
    match /laboratorios/{labId} {
      // Lectura pública
      allow read: if true;
      
      // Creación: solo usuarios autenticados
      allow create: if request.auth != null;
      
      // Actualización: solo el creador puede modificar
      // Pero cualquiera puede incrementar descargas/vistas
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.usuarioId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['descargas', 'vistas'])
      );
      
      // Eliminación: solo el creador
      allow delete: if request.auth != null && request.auth.uid == resource.data.usuarioId;
    }
    
    // ============================================
    // PROGRESO DE USUARIOS
    // ============================================
    match /progreso/{progresoId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.usuarioId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.usuarioId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.usuarioId;
    }
    
    // ============================================
    // CATEGORÍAS (solo lectura pública)
    // ============================================
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if false;
    }
    
    // ============================================
    // TOKENS FCM (notificaciones)
    // ============================================
    match /fcm_tokens/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ============================================
    // SUSCRIPCIONES A TEMAS
    // ============================================
    match /suscripciones_temas/{suscripcionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.usuarioId;
    }
  }
}
